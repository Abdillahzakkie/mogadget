# ── MoGadget environment ─────────────────────────────────────────────────────
# Copy to .env (git-ignored) and adjust. Every value has a safe local-dev default,
# so an empty .env still boots against local Mongo + Redis. CHANGE the secrets and
# seed credentials before any real deploy.

# ── Runtime ───────────────────────────────────────────────────────────────────
# Set NODE_ENV=production in production. The app then REFUSES to boot if
# SESSION_SECRET is left at its dev default, and issues the session cookie as Secure.
NODE_ENV=development

# ── Datastores (hard requirements — bootstrap pings both at boot) ─────────────
MONGODB_URI=mongodb://127.0.0.1:27017/mogadget
REDIS_URL=redis://127.0.0.1:6379

# ── Auth / session ────────────────────────────────────────────────────────────
# HS256 JWT secret, shared by the API route handlers and the edge proxy (src/proxy.ts).
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_MAX_AGE=604800            # 7 days, in seconds

# ── Origins ───────────────────────────────────────────────────────────────────
SITE_URL=http://localhost:3000    # public origin; SSR self-fetches use it
NEXT_PUBLIC_SITE_URL=http://localhost:3000  # inlined for client WhatsApp links / OG URLs

# ── Proxy trust (rate-limit client identity) ──────────────────────────────────
# Leave false unless the app is reachable ONLY through a proxy/load-balancer that
# overwrites X-Forwarded-For. When false, forwarded headers are ignored and per-IP
# rate limits share one global bucket; when true, they key on the proxy-supplied
# forwarded header. Setting this to true on a directly-reachable app lets attackers
# spoof their IP and bypass the login rate limit.
TRUST_PROXY=false

# ── Image storage (pluggable driver) ──────────────────────────────────────────
# Defaults to "local" (disk) unless AWS_S3_BUCKET is set, then "s3".
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=.uploads          # on-disk store for the local driver
# AWS_S3_BUCKET=my-mogadget-bucket
# AWS_REGION=us-east-1
# CDN_BASE_URL=https://cdn.example.com   # public base for S3-served images

# ── Seed owner (change before deploy!) ────────────────────────────────────────
SEED_OWNER_USERNAME=owner
SEED_OWNER_PASSWORD=password

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
